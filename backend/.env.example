# SignBridge AI Backend Environment Variables

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Auth Configuration
JWT_SECRET=super-secret-key-change-in-production
JWT_ALGORITHM=HS256

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000

# Audio Configuration
TTS_LANGUAGE=en
TTS_SPEED=1.0

# Debug Mode
DEBUG=False
